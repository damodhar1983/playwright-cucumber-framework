{
  "name": "playwright-cucumber-framework",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js --require-module ts-node/register features/**/*.feature",
    "report": "node generate-report.js",
    "test:report": "npm run test && npm run report",
    "smoke": "cucumber-js --require-module ts-node/register --tags @smoke",
    "regression": "cucumber-js --require-module ts-node/register --tags @Regression",
    "TC1": "cucumber-js --require-module ts-node/register --tags @TC1",
    "TC2": "cucumber-js --require-module ts-node/register --tags @TC2",
    "TC3": "cucumber-js --require-module ts-node/register --tags @TC3",
    "runTestParallelely": "cucumber-js --require-module ts-node/register --parallel 3"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@cucumber/cucumber": "^9.2.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "cucumber-html-reporter": "^7.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
